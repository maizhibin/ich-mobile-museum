{
  "name": "ich-mobile-museum",
  "private": true,
  "version": "0.5.0",
  "packageManager": "pnpm@11.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
